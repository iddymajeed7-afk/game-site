<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Games Hub</title>

<style>
body {
  margin: 0;
  background: #141414;
  color: white;
  font-family: Arial, sans-serif;
}

/* Navbar */
.navbar {
  display: flex;
  align-items: center;
  padding: 15px;
  background: #000;
}

.logo {
  font-size: 22px;
  font-weight: bold;
  color: red;
}

/* Controls */
.controls {
  padding: 10px;
  text-align: center;
}

button {
  padding: 8px 12px;
  margin: 5px;
  background: #333;
  color: white;
  border: none;
  cursor: pointer;
}

/* Rows */
.row {
  margin: 20px;
}

.row h2 {
  margin-bottom: 10px;
}

.row-games {
  display: flex;
  overflow-x: auto;
  gap: 10px;
}

/* Cards */
.card {
  min-width: 160px;
  height: 90px;
  background: #222;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  border-radius: 6px;
  transition: 0.2s;
}

.card:hover {
  transform: scale(1.1);
  background: #333;
}

/* Player */
#player {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: black;
  display: none;
}

#player iframe {
  width: 100%;
  height: 100%;
  border: none;
}

#closeBtn {
  position: absolute;
  top: 10px;
  left: 10px;
  padding: 10px;
  background: red;
  border: none;
  color: white;
  cursor: pointer;
}
</style>
</head>

<body>

<div class="navbar">
  <div class="logo">🎮 GameFlix</div>
</div>

<div class="controls">
  <button onclick="setTitle()">Change Tab Name</button>
  <button onclick="goHome()">Home</button>
</div>

<!-- ROW 1 -->
<div class="row">
  <h2>Popular</h2>
  <div class="row-games">
    <div class="card" onclick="play('https://html5.gamedistribution.com/rvvASMiM/6b1c9f6e4cde4b7bb0f1c5d6a5a5a111/index.html')">Slope</div>
    <div class="card" onclick="play('https://html5.gamedistribution.com/rvvASMiM/2c1b2c3d4e5f67890123456789abcdef/index.html')">Run Game</div>
    <div class="card" onclick="play('https://example.com')">Game 3</div>
    <div class="card" onclick="play('https://example.com')">Game 4</div>
    <div class="card" onclick="play('https://example.com')">Game 5</div>
  </div>
</div>

<!-- ROW 2 -->
<div class="row">
  <h2>Puzzle</h2>
  <div class="row-games">
    <div class="card" onclick="play('https://example.com')">Game 6</div>
    <div class="card" onclick="play('https://example.com')">Game 7</div>
    <div class="card" onclick="play('https://example.com')">Game 8</div>
    <div class="card" onclick="play('https://example.com')">Game 9</div>
    <div class="card" onclick="play('https://example.com')">Game 10</div>
  </div>
</div>

<!-- PLAYER -->
<div id="player">
  <button id="closeBtn" onclick="closeGame()">X</button>
  <iframe id="frame"></iframe>
</div>

<script>
function play(url) {
  document.getElementById("player").style.display = "block";
  document.getElementById("frame").src = url;
}

function closeGame() {
  document.getElementById("player").style.display = "none";
  document.getElementById("frame").src = "";
}

function goHome() {
  closeGame();
}

function setTitle() {
  let name = prompt("Enter tab name:");
  if (name) document.title = name;
}
</script>

</body>
</html>
